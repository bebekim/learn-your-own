{
  "name": "lyo-kernel",
  "version": "0.1.2",
  "description": "SQLite reducer kernel for evidence-backed agent learning protocols.",
  "type": "module",
  "files": [
    "src",
    "README.md"
  ],
  "bin": {
    "lyo": "./src/cli.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "test": "node --test",
    "lyo:init": "node src/cli.ts init --db .agent-learning/learning.sqlite",
    "lyo:report": "node src/cli.ts report --db .agent-learning/learning.sqlite",
    "demo": "node src/cli.ts demo fixture-replay",
    "pack:local": "node scripts/pack-npm.mjs",
    "publish:registry": "node scripts/publish-npm.mjs"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/bebekim/learn-your-own.git"
  },
  "keywords": [
    "agent-learning",
    "sqlite",
    "reducer",
    "codex",
    "workflow"
  ],
  "license": "MIT"
}
