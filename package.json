{
  "name": "lyo-kernel",
  "version": "0.2.1",
  "description": "SQLite reducer kernel for evidence-backed agent learning protocols.",
  "type": "module",
  "files": [
    "src",
    "docs/candidate-at-bat-telemetry-spec.md",
    "docs/cybernetic-association-learner.md",
    "docs/cybernetic-learning-experiment-protocol.md",
    "docs/deterministic-classification.md",
    "docs/product-learning-log.md",
    "docs/style-learning.md",
    "README.md",
    "CHANGELOG.md",
    "LICENSE.md"
  ],
  "bin": {
    "lyo": "./src/cli.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build:npm": "node scripts/build-npm.mjs",
    "test": "node --test",
    "typecheck": "tsc --noEmit",
    "lyo:init": "node src/cli.ts init --db .agent-learning/learning.sqlite",
    "lyo:report": "node src/cli.ts report --db .agent-learning/learning.sqlite",
    "demo": "node src/cli.ts demo fixture-replay",
    "pack:local": "node scripts/pack-npm.mjs",
    "publish:registry": "node scripts/publish-npm.mjs"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/bebekim/learn-your-own.git"
  },
  "keywords": [
    "agent-learning",
    "sqlite",
    "reducer",
    "codex",
    "workflow"
  ],
  "license": "SEE LICENSE IN LICENSE.md",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
